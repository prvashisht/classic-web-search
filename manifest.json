{
  "manifest_version": 3,
  "name": "Classic Web Search for Google",
  "short_name": "Classic Web",
  "version": "1.5.0",
  "description": "Automatically redirects your Google searches to the classic web-only results view.",
  "author": "Pratyush Vashisht",
  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },
  "host_permissions": [
    "*://*.google.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Enable / Disable Classic Web Search for Google"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+W",
        "mac": "Alt+Shift+W"
      },
      "description": "Toggle Classic Web Search for Google on/off"
    }
  },
  "permissions": [
    "contextMenus",
    "storage",
    "tabs"
  ]
}
